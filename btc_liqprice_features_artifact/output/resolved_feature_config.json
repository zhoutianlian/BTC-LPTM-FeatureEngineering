{
  "paths": {
    "input": "liq_dataflow/data/features/feature_store.csv",
    "output": "btc_liqprice_features_artifact/output/liqprice_features.csv",
    "resolved_config_output": "btc_liqprice_features_artifact/output/resolved_feature_config.json",
    "run_manifest": "btc_liqprice_features_artifact/output/run_manifest.json",
    "log_dir": "btc_liqprice_features_artifact/logs"
  },
  "columns": {
    "time_col": "time",
    "price_col": "price",
    "fll_col": "fll_cwt_kf",
    "fsl_col": "fsl_cwt_kf",
    "output_time_col": "time",
    "output_features": [
      "fll_spike_kama",
      "fsl_spike_kama",
      "fll_velocity_gaussian",
      "fll_acceleration_gaussian",
      "fsl_velocity_gaussian",
      "fsl_acceleration_gaussian",
      "trend_pressure",
      "kalman_slope",
      "vol_adaptive"
    ],
    "aliases": {
      "close": "price",
      "close_price": "price",
      "mark_price": "price",
      "last_price": "price",
      "long_liq_cwt_kf": "fll_cwt_kf",
      "short_liq_cwt_kf": "fsl_cwt_kf"
    }
  },
  "feature_config": {
    "bar_minutes": null,
    "decision_minutes": null,
    "liq_spike_window_min": 1440,
    "liq_kama_fast_ema": 2,
    "liq_kama_slow_ema": 30,
    "liq_roc_gaussian_window_min": 130,
    "trend_pressure_mom_window_min": 180,
    "trend_pressure_vol_window_min": 720,
    "price_kalman_process_noise": 1e-06,
    "price_kalman_slope_process_noise": 1e-07,
    "price_kalman_measurement_noise": 0.0001,
    "price_vol_adaptive_short_window_min": 360,
    "price_vol_adaptive_long_window_min": 1440,
    "price_vol_adaptive_min_weight": 0.3,
    "price_vol_adaptive_sigmoid_gamma": 3.0
  },
  "report": {
    "enabled": true,
    "output_dir": "btc_liqprice_features_artifact/reports/feature_diagnostics",
    "feature_doc_path": "btc_liqprice_features_artifact/docs/liqprice_feature_engineering.md",
    "generate_html": true,
    "generate_summary_json": true,
    "rolling_window_minutes": 1440,
    "rolling_quantiles": [
      0.05,
      0.95
    ],
    "min_valid_count": 30,
    "missing_warn_ratio": 0.05,
    "missing_fail_ratio": 0.5,
    "inf_fail_count": 1,
    "zscore_threshold": 4.0,
    "iqr_multiplier": 3.0,
    "extreme_quantile_low": 0.01,
    "extreme_quantile_high": 0.99,
    "max_outlier_examples": 30,
    "constant_rtol": 1e-10,
    "constant_atol": 1e-12,
    "long_constant_min_bars": 24,
    "time_gap_multiplier": 3.0,
    "cliff_mad_multiplier": 20.0,
    "explosion_mad_multiplier": 1000.0,
    "high_corr_threshold": 0.95,
    "correlation_method": "pearson",
    "future_return_periods": [
      1,
      3,
      6
    ],
    "price_context_enabled": true
  }
}